<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Override default target framework -->
        <TargetFramework>netstandard2.1</TargetFramework>

        <!-- Project Specific Configuration -->
        <RootNamespace>Nuuvify.CommonPack.Security.Abstraction</RootNamespace>
        <AssemblyName>Nuuvify.CommonPack.Security.Abstraction</AssemblyName>
        <Product>Nuuvify CommonPack Security Abstraction</Product>

        <!-- Package Specific Metadata -->
        <PackageId>Nuuvify.CommonPack.Security.Abstraction</PackageId>
        <Title>Nuuvify CommonPack Security Abstraction</Title>
        <Description>Essa biblioteca contem abstrações (interfaces) e demais classes auxilires para a lib que implementa Security. Essa biblioteca pode ser instalada em qualquer projeto da sua solução, diferente da biblioteca de Security que deve ser instalada apenas no seu projeto de IoC</Description>
        <Summary>Security abstractions (interfaces) and helper classes for Nuuvify Security library</Summary>

        <!-- Package Specific Tags -->
        <PackageTags>security;abstractions;interfaces;jwt;claims;principal;extensions;nuuvify;dotnet;netstandard</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.ComponentModel.Annotations" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Nuuvify.CommonPack.Extensions\Nuuvify.CommonPack.Extensions.csproj" />
    </ItemGroup>

</Project>
