<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Override default target framework -->
        <TargetFramework>netstandard2.1</TargetFramework>

        <!-- Project Specific Configuration -->
        <RootNamespace>Nuuvify.CommonPack.Extensions</RootNamespace>
        <AssemblyName>Nuuvify.CommonPack.Extensions</AssemblyName>
        <Product>Nuuvify CommonPack Extensions</Product>

        <!-- Package Specific Metadata -->
        <PackageId>Nuuvify.CommonPack.Extensions</PackageId>
        <Title>Nuuvify CommonPack Extensions</Title>
        <Description>This library implements Notification Pattern, which allows passing notifications between projects. Here there are also several extension methods that help handle null lists, special characters in strings, among other useful things.</Description>
        <Summary>Notification Pattern implementation with useful extension methods for .NET</Summary>

        <!-- Package Specific Tags -->
        <PackageTags>notification;pattern;extensions;helpers;string;list;null-handling;nuuvify;dotnet;netstandard</PackageTags>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.CSharp" Version="4.7.0" />
        <PackageReference Include="System.ComponentModel.Annotations" Version="5.0.0" />
        <PackageReference Include="System.Runtime.Extensions" Version="4.3.1" />
        <PackageReference Include="System.Diagnostics.DiagnosticSource" Version="8.0.1" />
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="8.0.3" />
        <PackageReference Include="Microsoft.Extensions.Logging.Configuration" Version="8.0.1" />
        <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="8.0.1" />
        <PackageReference Include="Microsoft.Extensions.Logging" Version="8.0.1" />
        <PackageReference Include="Microsoft.Extensions.Options" Version="8.0.2" />
        <PackageReference Include="System.Text.Json" Version="8.0.5" />
    </ItemGroup>

</Project>
