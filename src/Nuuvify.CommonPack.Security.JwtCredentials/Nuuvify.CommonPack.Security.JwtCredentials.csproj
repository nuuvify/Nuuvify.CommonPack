<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.1</TargetFramework>
        <PackageId>Nuuvify.CommonPack.Security.JwtCredentials</PackageId>
        <Title>Nuuvify CommonPack Security JWT Credentials</Title>
        <PackageTags>Nuuvify, Security, JWT, Credentials, .NET</PackageTags>
        <Description>Gerencia seu JWK e proteção do seu JWT signing</Description>
        <Product>CommonPack Security JWT Credentials</Product>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Caching.SqlServer" />
        <PackageReference Include="Microsoft.Extensions.Options" />
        <PackageReference Include="Microsoft.IdentityModel.Tokens" />
        <PackageReference Include="System.IdentityModel.Tokens.Jwt" />
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\Nuuvify.CommonPack.Security.Abstraction\Nuuvify.CommonPack.Security.Abstraction.csproj" />
    </ItemGroup>

    <ItemGroup>
        <Compile Update="Resources\MsgSecurityJwt.Designer.cs">
            <DesignTime>True</DesignTime>
            <AutoGen>True</AutoGen>
            <DependentUpon>MsgSecurityJwt.resx</DependentUpon>
        </Compile>
    </ItemGroup>

    <ItemGroup>
        <EmbeddedResource Update="Resources\MsgSecurityJwt.pt-BR.resx">
            <Generator>PublicResXFileCodeGenerator</Generator>
        </EmbeddedResource>
        <EmbeddedResource Update="Resources\MsgSecurityJwt.resx">
            <Generator>PublicResXFileCodeGenerator</Generator>
            <LastGenOutput>MsgSecurityJwt.Designer.cs</LastGenOutput>
        </EmbeddedResource>
    </ItemGroup>

</Project>
